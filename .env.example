# ============================================================
# Your AIOS Workspace — Environment Configuration
# ============================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control — it contains your secrets.
# The .gitignore file already prevents this, but be careful.
#
# As you install more AIOS modules, each one will tell you which
# API keys to add here. This file grows with your workspace.
# ============================================================

# --- Core AI Keys ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Add more keys below as you install modules ---
# Each module's INSTALL.md will tell you exactly what to add.

# --- TCL Client: Fleetx Integration ---
# Ishan's Fleetx login credentials (used by scripts/tcl/fleetx_tracker.py)
FLEETX_EMAIL=demoblr@tclpl.commit
FLEETX_PASSWORD=
